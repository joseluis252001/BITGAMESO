{
  "version": 2,
  "redirects": [
    {
      "source": "/",
      "destination": "/PaginaWeb/Bitgameso/src/PaginaMenu/index.html",
      "permanent": false
    },
    {
      "source": "/juego",
      "destination": "/PaginaWeb/Bitgameso/src/Game/game.html",
      "permanent": false
    },
    {
      "source": "/login",
      "destination": "/PaginaWeb/Bitgameso/src/InicioCuenta/inico.html",
      "permanent": false
    },
    {
      "source": "/registro",
      "destination": "/PaginaWeb/Bitgameso/src/CrearCuenta/registro.html",
      "permanent": false
    },
    {
      "source": "/privacidad",
      "destination": "/PaginaWeb/Bitgameso/src/PaginaMenu/privacidad.html",
      "permanent": false
    },
    {
      "source": "/reset-password",
      "destination": "/PaginaWeb/Bitgameso/src/InicioCuenta/reset-password.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",   "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection",          "value": "1; mode=block" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    }
  ]
}